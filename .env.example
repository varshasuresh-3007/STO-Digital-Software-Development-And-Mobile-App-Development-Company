# EmailJS Configuration
# Sign up at https://www.emailjs.com/ to get these keys:
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# Default template (e.g. for Contact Us form)
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here

# (Optional) Specific templates for different forms
VITE_EMAILJS_TEMPLATE_ID_QUOTE=your_quote_template_id_here
VITE_EMAILJS_TEMPLATE_ID_CONSULTATION=your_consultation_template_id_here
